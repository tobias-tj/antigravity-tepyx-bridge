{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020", 
    "lib": [
      "ES2020",
      "DOM" 
    ],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}